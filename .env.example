# Bot Configuration
GUEST_BOT_TOKEN=your_guest_bot_token_here
STAFF_BOT_TOKEN=your_staff_bot_token_here

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tokio_bar
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# Database Connection Pool (tune for high load)
# min_size: persistent connections kept open
# max_size: maximum concurrent connections (must be ≤ PostgreSQL max_connections)
# command_timeout: SQL query timeout in seconds
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=15
DB_COMMAND_TIMEOUT=60

# Application Settings
LOG_LEVEL=INFO
TIMEZONE=Europe/Moscow

# Restaurant Settings
TOTAL_TABLES=7

# Network (optional) — uncomment and set if Telegram API is blocked in your region
# Supported formats:
#   HTTP:  http://user:pass@host:port
#   SOCKS5: socks5://user:pass@host:port
# PROXY_URL=socks5://127.0.0.1:1080