# Bot Configuration
GUEST_BOT_TOKEN=your_guest_bot_token_here
STAFF_BOT_TOKEN=your_staff_bot_token_here

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tokio_bar
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# Database Connection Pool (tune for high load)
# min_size: persistent connections kept open
# max_size: maximum concurrent connections (must be ≤ PostgreSQL max_connections)
# command_timeout: SQL query timeout in seconds
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=15
DB_COMMAND_TIMEOUT=60

# Application Settings
LOG_LEVEL=INFO
TIMEZONE=Europe/Moscow

# Restaurant Settings
TOTAL_TABLES=7

# Admin bootstrap credentials (used only to create the default admin on first run).
# If ADMIN_PASSWORD is left empty, a random one-time password is generated and
# printed to the logs once; the admin must change it on first login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Redis (sessions + FSM storage)
# Strongly recommended for production / multi-instance deployments.
# When empty, the bot uses in-memory storage (single-instance, dev only).
# In docker-compose the default is redis://redis:6379/0.
REDIS_URL=redis://localhost:6379/0
# Session lifetime in seconds (24h default). Sliding expiration: refreshed on
# each access, so active staff stay logged in while inactive ones expire.
REDIS_SESSION_TTL=86400
# FSM state/data lifetime in seconds (24h default).
REDIS_FSM_STATE_TTL=86400
REDIS_FSM_DATA_TTL=86400

# Network (optional) — uncomment and set if Telegram API is blocked in your region
# Supported formats:
#   HTTP:   http://user:pass@host:port  (uses aiohttp native CONNECT tunneling)
#   SOCKS5: socks5://user:pass@host:port  (uses aiohttp-socks)
# HTTP proxies are handled via aiohttp's native proxy= parameter, which
# correctly tunnels HTTPS traffic (fixes ConnectionResetError that occurred
# with aiohttp-socks for HTTP proxies).
# PROXY_URL=http://127.0.0.1:10808
